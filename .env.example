NODE_ENV=development
HOST=0.0.0.0
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/express_prisma_postgres_api?schema=public
SHADOW_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/express_prisma_postgres_api_shadow?schema=public
JWT_SECRET=change-me-with-at-least-32-characters-in-real-projects
JWT_ISSUER=express-prisma-postgres-api
JWT_AUDIENCE=express-prisma-postgres-api-users
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
